<Window
    x:Class="RepoBar.Desktop.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:RepoBar.Desktop.ViewModels"
    x:DataType="vm:ShellViewModel"
    Title="RepoBar"
    Width="1040"
    Height="760"
    MinWidth="860"
    MinHeight="620"
    ShowInTaskbar="False">
  <Window.Styles>
    <Style Selector="TextBlock.sectionTitle">
      <Setter Property="FontSize" Value="16" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="TextBlock.subtle">
      <Setter Property="Opacity" Value="0.72" />
    </Style>
    <Style Selector="Border.panel">
      <Setter Property="BorderBrush" Value="#333333" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="14" />
      <Setter Property="Background" Value="#151515" />
    </Style>
    <Style Selector="Border.card">
      <Setter Property="BorderBrush" Value="#3A3A3A" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="12" />
      <Setter Property="Background" Value="#1B1B1B" />
    </Style>
    <Style Selector="Button.iconText">
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="Padding" Value="12,6" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,*" Background="#0F0F0E">
    <Border Padding="18,14" Background="#171715" BorderBrush="#2E2E2A" BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
        <StackPanel Spacing="2">
          <TextBlock Text="RepoBar" FontSize="22" FontWeight="SemiBold" />
          <TextBlock Text="{Binding AccountSummary}" Classes="subtle" />
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
          <Button Classes="iconText" Content="Refresh" Command="{Binding RefreshCommand}" />
          <Button Classes="iconText" Content="Settings" Command="{Binding ShowSettingsCommand}" />
          <Button Classes="iconText" Content="Quit" Command="{Binding QuitCommand}" />
        </StackPanel>
        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="14" Margin="0,12,0,0">
          <TextBlock Text="{Binding SelectedProviderLabel}" />
          <TextBlock Text="{Binding CacheStatus}" Classes="subtle" />
          <TextBlock Text="{Binding RateLimitSummary}" Classes="subtle" />
        </StackPanel>
      </Grid>
    </Border>

    <TabControl Grid.Row="1" SelectedIndex="{Binding SelectedPrimaryTabIndex}" Margin="14">
      <TabItem Header="Dashboard">
        <Grid ColumnDefinitions="2*,1.1*" ColumnSpacing="14">
          <ScrollViewer>
            <ItemsControl ItemsSource="{Binding Repositories}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:RepositoryCardViewModel">
                  <Border Classes="card" Width="310" Margin="0,0,12,12">
                    <StackPanel Spacing="10">
                      <Grid ColumnDefinitions="*,Auto">
                        <StackPanel>
                          <TextBlock Text="{Binding Name}" FontSize="17" FontWeight="SemiBold" />
                          <TextBlock Text="{Binding Owner}" Classes="subtle" />
                        </StackPanel>
                        <Border Background="#24452E" CornerRadius="4" Padding="7,3">
                          <TextBlock Text="{Binding ProviderLabel}" FontSize="12" />
                        </Border>
                      </Grid>
                      <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="6">
                        <TextBlock Text="{Binding IssueSummary}" />
                        <TextBlock Grid.Column="1" Text="{Binding PullRequestSummary}" />
                        <TextBlock Grid.Row="1" Text="{Binding CiSummary}" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding RateLimitText}" />
                      </Grid>
                      <TextBlock Text="{Binding ReleaseSummary}" TextWrapping="Wrap" />
                      <TextBlock Text="{Binding ActivitySummary}" TextWrapping="Wrap" Classes="subtle" />
                      <TextBlock Text="{Binding TrafficSummary}" TextWrapping="Wrap" Classes="subtle" />
                      <TextBlock Text="{Binding HeatmapSummary}" TextWrapping="Wrap" Classes="subtle" />
                      <Border Background="#10100F" CornerRadius="6" Padding="8">
                        <TextBlock Text="{Binding LocalStatus}" TextWrapping="Wrap" />
                      </Border>
                      <TextBlock Text="{Binding CacheSource}" Classes="subtle" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>

          <Border Grid.Column="1" Classes="panel">
            <Grid RowDefinitions="Auto,Auto,*">
              <StackPanel Spacing="4">
                <TextBlock Text="Repository Details" Classes="sectionTitle" />
                <TextBlock Text="{Binding SelectedRepository.FullName}" Classes="subtle" />
              </StackPanel>
              <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,12,0,12">
                <Button Content="Open" Command="{Binding OpenSelectedRepositoryCommand}" />
                <Button Content="Pin" Command="{Binding PinSelectedRepositoryCommand}" />
                <Button Content="Hide" Command="{Binding HideSelectedRepositoryCommand}" />
              </StackPanel>
              <ScrollViewer Grid.Row="2">
                <ItemsControl ItemsSource="{Binding DetailSections}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:DetailSectionViewModel">
                    <Border BorderBrush="#30302C" BorderThickness="0,0,0,1" Padding="0,10">
                        <StackPanel Spacing="4">
                          <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="{Binding Availability}" Classes="subtle" />
                          </Grid>
                          <TextBlock Text="{Binding Detail}" TextWrapping="Wrap" Classes="subtle" />
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </Grid>
          </Border>
        </Grid>
      </TabItem>

      <TabItem Header="Settings">
        <Grid ColumnDefinitions="1.1*,2*" ColumnSpacing="14">
          <Border Classes="panel">
            <StackPanel Spacing="12">
              <TextBlock Text="Settings" Classes="sectionTitle" />
              <ItemsControl ItemsSource="{Binding SettingsTabs}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:SettingsTabViewModel">
                    <Border BorderBrush="#30302C" BorderThickness="0,0,0,1" Padding="0,8">
                      <StackPanel>
                        <TextBlock Text="{Binding Header}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Summary}" TextWrapping="Wrap" Classes="subtle" />
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <ScrollViewer Grid.Column="1">
            <StackPanel Spacing="14">
              <Border Classes="panel">
                <StackPanel Spacing="10">
                  <TextBlock Text="Account" Classes="sectionTitle" />
                  <ItemsControl ItemsSource="{Binding ProviderOptions}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:ProviderOptionViewModel">
                        <Grid ColumnDefinitions="160,*" Margin="0,4">
                          <TextBlock Text="{Binding Label}" FontWeight="SemiBold" />
                          <TextBlock Grid.Column="1" Text="{Binding Availability}" Classes="subtle" />
                        </Grid>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                  <TextBox PlaceholderText="Personal access token" PasswordChar="*" Text="{Binding PatToken}" />
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Save PAT" Command="{Binding SavePatCommand}" />
                    <Button Content="Log out" Command="{Binding LogoutCommand}" />
                  </StackPanel>
                  <TextBox PlaceholderText="GitHub Enterprise host" Text="{Binding GitHubEnterpriseHost}" />
                  <TextBox PlaceholderText="Loopback port" Text="{Binding LoopbackPort}" />
                  <TextBox PlaceholderText="OAuth client ID" Text="{Binding OAuthClientId}" />
                  <TextBox PlaceholderText="OAuth client secret" PasswordChar="*" Text="{Binding OAuthClientSecret}" />
                  <TextBox PlaceholderText="OAuth scope" Text="{Binding OAuthScope}" />
                  <Button Content="Start OAuth" Command="{Binding StartOAuthCommand}" />
                </StackPanel>
              </Border>

              <Border Classes="panel">
                <StackPanel Spacing="10">
                  <TextBlock Text="General" Classes="sectionTitle" />
                  <Grid ColumnDefinitions="220,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8">
                    <TextBlock Text="Display limit" />
                    <NumericUpDown Grid.Column="1" Minimum="1" Maximum="50" Value="{Binding DisplayLimit}" />
                    <TextBlock Grid.Row="1" Text="Refresh interval" />
                    <NumericUpDown Grid.Row="1" Grid.Column="1" Minimum="1" Maximum="60" Value="{Binding RefreshIntervalMinutes}" />
                    <CheckBox Grid.Row="2" Grid.ColumnSpan="2" Content="Launch at login" IsChecked="{Binding LaunchAtLogin}" />
                    <CheckBox Grid.Row="3" Grid.ColumnSpan="2" Content="Show contribution header" IsChecked="{Binding ShowContributionHeader}" />
                  </Grid>
                </StackPanel>
              </Border>

              <Border Classes="panel">
                <StackPanel Spacing="10">
                  <TextBlock Text="Repositories" Classes="sectionTitle" />
                  <TextBox PlaceholderText="Search repositories" Text="{Binding RepositorySearchQuery}" />
                  <ItemsControl ItemsSource="{Binding RepositoryBrowserRows}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:RepositoryBrowserRowViewModel">
                        <Grid ColumnDefinitions="*,90,90" Margin="0,3">
                          <TextBlock Text="{Binding FullName}" />
                          <TextBlock Grid.Column="1" Text="{Binding ProviderLabel}" Classes="subtle" />
                          <TextBlock Grid.Column="2" Text="{Binding Visibility}" Classes="subtle" />
                        </Grid>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </Border>

              <Border Classes="panel">
                <StackPanel Spacing="10">
                  <TextBlock Text="Local Projects" Classes="sectionTitle" />
                  <TextBox PlaceholderText="Project folder" Text="{Binding LocalProjectsRoot}" />
                  <NumericUpDown Minimum="0" Maximum="12" Value="{Binding LocalProjectsDepth}" />
                  <CheckBox Content="Auto-sync clean behind repositories" IsChecked="{Binding AutoSyncEnabled}" />
                </StackPanel>
              </Border>

              <Border Classes="panel">
                <StackPanel Spacing="10">
                  <TextBlock Text="Cache, Diagnostics, Startup" Classes="sectionTitle" />
                  <CheckBox Content="Show rate-limit meter" IsChecked="{Binding ShowRateLimitMeter}" />
                  <CheckBox Content="Enable diagnostics" IsChecked="{Binding DiagnosticsEnabled}" />
                  <TextBlock Text="{Binding CacheStatus}" Classes="subtle" />
                  <Button Content="Save Settings" Command="{Binding SaveSettingsCommand}" />
                </StackPanel>
              </Border>
            </StackPanel>
          </ScrollViewer>
        </Grid>
      </TabItem>
    </TabControl>
  </Grid>
</Window>
